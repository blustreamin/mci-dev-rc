+            .filter(r => (r.volume || 0) > 0)
+            .sort((a, b) => (b.volume || 0) - (a.volume || 0))
+            .slice(0, 20)
+            .map(r => ({ keyword: r.keyword_text, volume: r.volume || 0 }));
